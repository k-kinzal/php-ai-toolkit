#!/usr/bin/env php
<?php

declare(strict_types=1);

use PhpAiToolkit\LocGuard\Cli\Application;

if (PHP_VERSION_ID < 80000) {
    fwrite(
        STDERR,
        'loc-guard requires PHP 8.0 or later.' . PHP_EOL,
    );

    exit(1);
}

$autoloadPaths = [];

if (isset($GLOBALS['_composer_autoload_path'])) {
    $autoloadPaths[] = $GLOBALS['_composer_autoload_path'];
}

$autoloadPaths[] = __DIR__ . '/../vendor/autoload.php';
$autoloadPaths[] = __DIR__ . '/../../../autoload.php';

$autoloaderFound = false;

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(
        STDERR,
        'Could not find Composer autoloader. Run "composer install" first.' . PHP_EOL,
    );

    exit(1);
}

$workingDirectory = getcwd();
if ($workingDirectory === false) {
    $workingDirectory = dirname(__DIR__);
}

$app = new Application($workingDirectory);

exit($app->run($argv));
